# ===========================================
# Zen Bali Environment Configuration
# ===========================================
# Copy this file to .env and update values

# Server Configuration
PORT=8081
ENV=development
BASE_URL=http://localhost:8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=zenbali
DB_PASSWORD=zenbali_dev_password
DB_NAME=zenbali
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=5

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRY_HOURS=24

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CENTS=100

# Upload Storage
UPLOAD_BACKEND=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
GCS_BUCKET=
GCS_PREFIX=
GCS_PUBLIC_BASE_URL=

# Google credentials (only needed if the runtime does not already have ADC)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Redis Configuration
REDIS_PORT=6379

# Admin Configuration
ADMIN_EMAIL=admin@zenbali.org
ADMIN_PASSWORD=Teameditor@123
CREATOR_EMAIL=creator@zenbali.org
CREATOR_PASSWORD=admin123
AGENT_API_TOKEN=replace-with-a-long-random-token
AGENT_CREATOR_EMAIL=creator@zenbali.org

# GeoIP Configuration (optional - for visitor location)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
