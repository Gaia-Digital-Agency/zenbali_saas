# Zen Bali VM Production Environment Example
# Target server: /var/www/zenbali on 34.124.244.233

PORT=8081
ENV=production
BASE_URL=https://zenbali.site

# Same-VM PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=zenbali
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=zenbali
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=5

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRY_HOURS=24

# Stripe
# Replace these with final live credentials before production launch.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CENTS=500

# Uploads
UPLOAD_BACKEND=gcs
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
GCS_BUCKET=gda-s01-bucket
GCS_PREFIX=zenbali
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/gda-s01-bucket

# Google credentials
# If the VM already runs with a service account that has Storage access, this can be omitted.
GOOGLE_APPLICATION_CREDENTIALS=/var/www/zenbali/secrets/gcs-service-account.json

# Redis
REDIS_PORT=6379

# Default accounts
ADMIN_EMAIL=admin@zenbali.org
ADMIN_PASSWORD=Teameditor@123
CREATOR_EMAIL=creator@zenbali.org
CREATOR_PASSWORD=admin123
